{
  "title": "Experiments",
  "rules": [
    {
      "description": "Caps Lock - Fallback (Shift + Command <-> R Control) ",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "right_control",
            "modifiers": {
              "mandatory": ["shift", "command"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "caps_lock"
            }
          ],
          "description": "For Claude Code shortcut. Makes Hyper-ish chords harder, disabling for now"
        }
      ]
    },
    {
      "description": "Spacebar-Command Mode: Spacebar + Right Shift to Right Command",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "spacebar",
            "modifiers": { "mandatory": ["right_shift"] }
          },
          "to_if_held_down": [{ "key_code": "right_command" }],
          "to": [
            { "set_variable": { "name": "spacebar_command_mode", "value": 1 } }
          ],
          "to_after_key_up": [
            { "set_variable": { "name": "spacebar_command_mode", "value": 0 } }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "left_shift",
            "modifiers": { "optional": ["right_command"] }
          },
          "conditions": [
            {
              "type": "variable_if",
              "name": "spacebar_command_mode",
              "value": 1
            }
          ],
          "to": [{ "key_code": "spacebar" }]
        }
      ]
    },
    {
      "description": "Spacebar-Command Mode: Spacebar + Left Shift to Left Command",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "spacebar",
            "modifiers": { "mandatory": ["left_shift"] }
          },
          "to_if_held_down": [{ "key_code": "left_command" }],
          "to": [
            { "set_variable": { "name": "spacebar_command_mode", "value": 1 } }
          ],
          "to_after_key_up": [
            { "set_variable": { "name": "spacebar_command_mode", "value": 0 } }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "right_shift",
            "modifiers": { "optional": ["left_command"] }
          },
          "conditions": [
            {
              "type": "variable_if",
              "name": "spacebar_command_mode",
              "value": 1
            }
          ],
          "to": [{ "key_code": "spacebar" }]
        }
      ]
    },
    {
      "description": "Double Quotes for simultaneous Cmd + Single Quote",
      "manipulators": [
        {
          "type": "basic",
          "parameters": {
            "basic.simultaneous_threshold_milliseconds": 110
          },
          "from": {
            "simultaneous": [
              {
                "key_code": "left_command"
              },
              {
                "key_code": "quote"
              }
            ],
            "simultaneous_options": {
              "key_down_order": "strict",
              "key_up_order": "strict"
            }
          },
          "to": [
            {
              "key_code": "quote",
              "modifiers": ["left_shift"]
            }
          ],
          "description": "For Ergodox, I think"
        }
      ]
    },
    {
      "description": "Question Mark for simultaneous Cmd + Slash",
      "manipulators": [
        {
          "type": "basic",
          "parameters": {
            "basic.simultaneous_threshold_milliseconds": 110
          },
          "from": {
            "simultaneous": [
              {
                "key_code": "left_command"
              },
              {
                "key_code": "slash"
              }
            ],
            "simultaneous_options": {
              "key_down_order": "strict",
              "key_up_order": "strict"
            }
          },
          "to": [
            {
              "key_code": "slash",
              "modifiers": ["left_shift"]
            }
          ],
          "description": "For Ergodox, I think"
        }
      ]
    }
  ]
}
