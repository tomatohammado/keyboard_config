{
  "title": "Colemak Vim Navigation",
  "rules": [
    {
      "description": "Colemak Vim Navigation: Activate via Right Shift + Space",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "spacebar",
            "modifiers": { "mandatory": ["right_shift"] }
          },
          "to": [
            { "set_variable": { "name": "colemak_vim_nav", "value": 1 } },
            { "shell_command": "/opt/homebrew/bin/hs -c 'vimOn()'" }
          ],
          "to_after_key_up": [
            { "set_variable": { "name": "colemak_vim_nav", "value": 0 } },
            { "shell_command": "/opt/homebrew/bin/hs -c 'vimOff()'" }
          ]
        }
      ]
    },
    {
      "description": "Colemak Vim Navigation: Arrows, Page Up/Down, Home/End (Non-built-in keyboard)",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "n" },
          "conditions": [
            { "type": "variable_if", "name": "colemak_vim_nav", "value": 1 },
            {
              "type": "device_if",
              "identifiers": [{ "is_built_in_keyboard": false }]
            }
          ],
          "to": [{ "key_code": "down_arrow" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "n", "modifiers": { "mandatory": ["shift"] } },
          "conditions": [
            { "type": "variable_if", "name": "colemak_vim_nav", "value": 1 },
            {
              "type": "device_if",
              "identifiers": [{ "is_built_in_keyboard": false }]
            }
          ],
          "to": [{ "key_code": "5" }, { "key_code": "down_arrow" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "e" },
          "conditions": [
            { "type": "variable_if", "name": "colemak_vim_nav", "value": 1 },
            {
              "type": "device_if",
              "identifiers": [{ "is_built_in_keyboard": false }]
            }
          ],
          "to": [{ "key_code": "up_arrow" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "e", "modifiers": { "mandatory": ["shift"] } },
          "conditions": [
            { "type": "variable_if", "name": "colemak_vim_nav", "value": 1 },
            {
              "type": "device_if",
              "identifiers": [{ "is_built_in_keyboard": false }]
            }
          ],
          "to": [{ "key_code": "5" }, { "key_code": "up_arrow" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "i" },
          "conditions": [
            { "type": "variable_if", "name": "colemak_vim_nav", "value": 1 },
            {
              "type": "device_if",
              "identifiers": [{ "is_built_in_keyboard": false }]
            }
          ],
          "to": [{ "key_code": "right_arrow" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "m" },
          "conditions": [
            { "type": "variable_if", "name": "colemak_vim_nav", "value": 1 },
            {
              "type": "device_if",
              "identifiers": [{ "is_built_in_keyboard": false }]
            }
          ],
          "to": [{ "key_code": "left_arrow" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "l" },
          "conditions": [
            { "type": "variable_if", "name": "colemak_vim_nav", "value": 1 },
            {
              "type": "device_if",
              "identifiers": [{ "is_built_in_keyboard": false }]
            }
          ],
          "to": [{ "key_code": "page_down" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "u" },
          "conditions": [
            { "type": "variable_if", "name": "colemak_vim_nav", "value": 1 },
            {
              "type": "device_if",
              "identifiers": [{ "is_built_in_keyboard": false }]
            }
          ],
          "to": [{ "key_code": "page_up" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "h" },
          "conditions": [
            { "type": "variable_if", "name": "colemak_vim_nav", "value": 1 },
            {
              "type": "device_if",
              "identifiers": [{ "is_built_in_keyboard": false }]
            }
          ],
          "to": [{ "key_code": "end" }]
        },
        {
          "type": "basic",
          "from": { "key_code": "comma" },
          "conditions": [
            { "type": "variable_if", "name": "colemak_vim_nav", "value": 1 },
            {
              "type": "device_if",
              "identifiers": [{ "is_built_in_keyboard": false }]
            }
          ],
          "to": [{ "key_code": "home" }]
        }
      ]
    },
    {
